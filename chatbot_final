<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chatbot</title>
    <link rel="stylesheet" href="https://pyscript.net/latest/pyscript.css" />
    <script defer src="https://pyscript.net/latest/pyscript.js"></script>
    <style>
        body {
            font-family: 'Comic Sans MS', sans-serif;
            background-image: url('https://media.istockphoto.com/id/1388281684/vector/seamless-dog-pattern-with-paw-prints-bones-hearts-and-balls-cat-foot-texture-pattern-with.jpg?s=612x612&w=0&k=20&c=St1dISSnU7zobbE4y1VWD7hhEnWcUGriSVZ5ocoSYWU=');
            background-size: cover;
            background-repeat: repeat;
            background-attachment: fixed;
            animation: moveBackground 30s linear infinite;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            padding: 0;
        }

        @keyframes moveBackground {
            0% { background-position: 0 0; }
            100% { background-position: 100% 100%; }
        }

        .chat-container {
            width: 90%;
            max-width: 420px;
            height: 600px;
            background-color: rgba(255, 248, 240, 0.9); /* Light beige with transparency */
            border: 2px solid #8B4513; /* Brown border */
            border-radius: 25px;
            box-shadow: 0px 5px 15px rgba(0, 0, 0, 0.3);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .chat-header {
            background-color: #CD853F; /* Safari-themed sandy color */
            color: #fff;
            padding: 15px;
            font-size: 22px;
            text-align: center;
            font-weight: bold;
            border-top-left-radius: 20px;
            border-top-right-radius: 20px;
        }

        #chatOutput {
            flex: 1;
            padding: 15px;
            background-color: rgba(255, 255, 240, 0.8); /* Light transparent color */
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
            border-bottom: 2px solid #CD853F;
        }

        .message {
            padding: 10px 15px;
            border-radius: 20px;
            max-width: 75%;
            font-size: 15px;
            line-height: 1.5;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
        }

        .user-message {
            justify-content: flex-end;
            background-color: #ffcccb;
            color: #610c0c;
            border-radius: 20px 20px 0 20px;
        }

        .bot-message {
            justify-content: flex-start;
            background-color: #fffacd;
            color: #8e501d;
            border-radius: 20px 20px 20px 0;
        }

        .profile {
            display: flex;
            align-items: center;
            margin-right: 10px;
            font-weight: bold;
        }

        .profile-pic {
            width: 30px; /* Smaller size for inline */
            height: 30px; /* Smaller size for inline */
            border-radius: 50%;
            margin-right: 5px;
        }

        

     /* Bone Button Styling */
     .bone-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 80px; /* Length of the bone */
            height: 40px; /* Height of the bone */
            background-color: #CD853F;
            border: none;
            cursor: pointer;
            position: relative;
            padding: 5px 15px;
            outline: none;
            transition: background-color 0.3s, transform 0.2s;
        }

        /* Round "ends" of the bone */
        .bone-button::before,
        .bone-button::after {
            content: "";
            position: absolute;
            width: 30px; /* Size of the rounded ends */
            height: 30px;
            background-color: #CD853F;
            border-radius: 50%;
        }

        .bone-button::before {
            left: -15px; /* Position to the left end */
        }

        .bone-button::after {
            right: -15px; /* Position to the right end */
        }

        .bone-button:hover {
            background-color: #B8860B;
            transform: scale(1.05); /* Scale effect on hover */
        }

        .bone-button:active {
            transform: scale(0.95); /* Scale down on active */
        }
/* Adjustments for the container */
.chat-input-container {
            display: flex;
            align-items: center;
            padding: 10px;
            background-color: #fffaf0;
            border-bottom-left-radius: 20px;
            border-bottom-right-radius: 20px;
        }

        input[type="text"] {
            flex: 1;
            padding: 10px;
            border: 2px solid #CD853F;
            border-radius: 25px;
            margin-right: 10px;
            font-size: 14px;
            outline: none;
        }
    </style>
</head>
<body>
    <div class="chat-container">
        <div class="chat-header">Chatbot</div>
        <div id="chatOutput"></div>
        <div class="chat-input-container">
            <input id="userInput" type="text" placeholder="Ask me anything...">
            <button id="sendBtn" class="bone-button">Send</button>
        </div>
    </div>


    <py-script>
        from pyscript import Element

        def respond(event):
            user_input = Element('userInput').element.value.lower()
            if "halo" in user_input:
                response = "Halo ada yang bisa saya bantu?"
            elif "hai" in user_input:
                response = "Haii ada yang bisa saya bantu?"
            elif "apa kabar" in user_input:
                response = "Saya baik-baik saja, terima kasih!"
            elif "rekomendasi" in user_input:
                response = "Hewan peliharaan apa yang anda miliki?"
            elif "kucing" in user_input:
                response = """Berikut rekomendasi nama untuk kucing anda:
                              <ul>
                                  <li>Milo</li>
                                  <li>Neko</li>
                                  <li>Kiki</li>
                                  <li>Loki</li>
                                  <li>Tara</li>
                              </ul>"""
            elif "anjing" in user_input:
                response = """Berikut rekomendasi nama untuk anjing anda:
                              <ul>
                                  <li>Chiko</li>
                                  <li>Belo</li>
                                  <li>Snowy</li>
                                  <li>Midnight</li>
                                  <li>Simba</li>
                              </ul>"""
            elif "burung" in user_input:
                response = """Berikut adalah rekomendasi nama untuk burung:
                              <ul>
                                  <li>Sky</li>
                                  <li>Sunny</li>
                                  <li>Lola</li>
                                  <li>Kiwi</li>
                                  <li>Pepper</li>
                              </ul>"""
            elif "ikan" in user_input:
                response = """Berikut rekomendasi nama untuk ikan anda:
                              <ul>
                                  <li>Lucky</li>
                                  <li>Nemo</li>
                                  <li>Bubbles</li>
                                  <li>Suki</li>
                                  <li>Yoda</li>
                              </ul>"""
            elif "kata kata hari ini" in user_input:
                response = "Jangan menyerah, tetaplah semangat karena masih banyak cobaan yang kau cobain😎"
            elif "lagi dong" in user_input:
                response = "Kegagalan bukan untuk ditakuti, melainkan untuk dipelajari"
            else:
                response = "Maaf, saya tidak mengerti."

            # Update chat output with user and bot messages alongside profiles
            Element('chatOutput').element.innerHTML += f"""
                <div class='message user-message'>
                        <img src='https://t4.ftcdn.net/jpg/02/29/75/83/360_F_229758328_7x8jwCwjtBMmC6rgFzLFhZoEpLobB6L8.jpg' alt='User Profile' class='profile-pic'>
                        <span>User</span>
                    </div>
                    {user_input}
                </div>
            """
            Element('chatOutput').element.innerHTML += f"""
                <div class='message bot-message'>
                        <img src='data:image/png;base64,' alt='Bot Profile' class='profile-pic'>
                        <span>Bot</span>
                    </div>
                    {response}
                </div>
            """
            Element('userInput').element.value = ""

        Element('sendBtn').element.onclick = respond
    </py-script>
</body>
</html>